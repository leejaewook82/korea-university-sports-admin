# Optional. Enables Gemini OCR for receipt images.
# If omitted, the app returns mock OCR data for testing.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional. Railway injects PORT automatically at runtime.
# Keep this only for local production testing.
PORT="3000"

# Optional. Railway Volumes expose RAILWAY_VOLUME_MOUNT_PATH automatically.
# Use DATA_DIR only when you want to override where db.json and uploads are stored.
DATA_DIR="./data"
